# ── Stage 1: build ──────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install

COPY frontend/ ./

# Empty string so all API calls go to the same origin (nginx proxies them)
ENV VITE_API_BASE_URL=""

RUN npm run build

# ── Stage 2: serve ───────────────────────────────────────────────────────────
FROM nginx:1.27-alpine

COPY --from=builder /app/dist /usr/share/nginx/html

# Place config in templates/ so nginx entrypoint runs envsubst on BACKEND_HOST
COPY nginx.conf /etc/nginx/templates/default.conf.template

# Default for local Docker Compose; overridden to "localhost" in ECS
ENV BACKEND_HOST=backend

EXPOSE 80
