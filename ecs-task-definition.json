{
  "family": "english-tutor",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::__ACCOUNT_ID__:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "__ACCOUNT_ID__.dkr.ecr.__REGION__.amazonaws.com/english-tutor-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8001,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:ssm:__REGION__:__ACCOUNT_ID__:parameter/english-tutor/OPENAI_API_KEY"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/english-tutor",
          "awslogs-region": "__REGION__",
          "awslogs-stream-prefix": "backend",
          "awslogs-create-group": "true"
        }
      }
    },
    {
      "name": "frontend",
      "image": "__ACCOUNT_ID__.dkr.ecr.__REGION__.amazonaws.com/english-tutor-frontend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "BACKEND_HOST",
          "value": "localhost"
        }
      ],
      "dependsOn": [
        {
          "containerName": "backend",
          "condition": "START"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/english-tutor",
          "awslogs-region": "__REGION__",
          "awslogs-stream-prefix": "frontend",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
